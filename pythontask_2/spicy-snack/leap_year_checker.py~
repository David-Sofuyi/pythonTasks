# PSEUDOCODE:
#  Input a year
#  Check:
#       If divisible by 4 and not by 100 = leap year
#       OR divisible by 400 = leap year
#       Else = Not Leap Year
#  Display result

year = int(input("Enter a year: "))

if (year % 4 == 0 and year % 100 != 0) or (year % 400 == 0):
    print(year, "is a Leap Year")
else:
    print(year, "is not a Leap Year")
